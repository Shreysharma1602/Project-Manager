{
  "version": 2,
  "name": "ethara-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@backend-url"
  },
  "build": {
    "env": {
      "VITE_API_URL": "@backend-url"
    }
  }
}
